---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalCard from "../../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import createSlug from "../../lib/createSlug";

export async function getStaticPaths({
  paginate,
}: {
  paginate: (
    data: CollectionEntry<"posts">[],
    opts: { pageSize: number },
  ) => unknown;
}) {
  const topics = (await getCollection("posts")).filter((entry) =>
    /^\d{2}-/.test(entry.id),
  );
  topics.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
  return paginate(topics, { pageSize: 10 });
}

const { page } = Astro.props as {
  page: {
    data: CollectionEntry<"posts">[];
    url: {
      prev: string | undefined;
      next: string | undefined;
    };
  };
};
---

<BaseLayout title="Ruta de aprendizaje" sideBarActiveItemID="ruta-aprendizaje">
  <div
    class="mb-8 rounded-2xl border border-base-300 bg-base-200/70 p-6 md:p-8"
  >
    <div class="badge badge-secondary mb-3">Ruta completa</div>
    <h1 class="text-3xl md:text-4xl font-extrabold leading-tight">
      Ruta de aprendizaje en Inteligencia Artificial
    </h1>
    <p class="mt-3 text-base md:text-lg opacity-90">
      Esta portada reune una ruta integral para estudiantes que quieren
      prepararse para olimpiadas y competencias de IA. Cada tema contiene
      teoria, aplicacion practica, errores frecuentes y una guia para pasar de
      conceptos basicos a resolucion de problemas reales.
    </p>
    <div class="mt-5 grid gap-3 md:grid-cols-2">
      <div class="rounded-xl bg-base-100 p-4 border border-base-300">
        <h2 class="font-bold text-lg">Como usar esta ruta</h2>
        <ul class="list-disc ml-5 mt-2 space-y-1">
          <li>Lee primero la teoria completa del tema.</li>
          <li>Resume ideas clave en tus propias palabras.</li>
          <li>Resuelve ejercicios antes de mirar soluciones.</li>
          <li>Implementa mini-proyectos con codigo reproducible.</li>
        </ul>
      </div>
      <div class="rounded-xl bg-base-100 p-4 border border-base-300">
        <h2 class="font-bold text-lg">Resultado esperado</h2>
        <ul class="list-disc ml-5 mt-2 space-y-1">
          <li>Base matematica y programacion solida.</li>
          <li>Dominio de ML clasico y deep learning.</li>
          <li>Manejo de NLP, transformers y LLMs.</li>
          <li>Metodologia competitiva estilo Kaggle/IOAI.</li>
        </ul>
      </div>
    </div>
    <div class="mt-5 rounded-xl bg-base-100 p-4 border border-base-300">
      <h2 class="font-bold text-lg">Mapa de fases</h2>
      <p class="mt-2 opacity-80">
        Fase 1: Fundamentos. Fase 2: ML clasico. Fase 3: Deep Learning. Fase 4:
        NLP moderno. Fase 5: Competencias, etica y proyecto final.
      </p>
    </div>
  </div>

  {
    page.data.length === 0 ? (
      <div class="bg-base-200 border-l-4 border-secondary w-full p-4 min-w-full">
        <p class="font-bold">Aun no hay contenido.</p>
        <p>Pronto publicaremos los temas de la ruta de aprendizaje.</p>
      </div>
    ) : (
      <ul>
        {page.data.map((topic) => (
          <>
            <HorizontalCard
              title={topic.data.title}
              img={topic.data.heroImage}
              desc={topic.data.description}
              url={
                "/ruta-aprendizaje/" + createSlug(topic.data.title, topic.slug)
              }
              target="_self"
              badge={topic.data.badge}
              tags={topic.data.tags}
            />
            <div class="divider my-0" />
          </>
        ))}
      </ul>
    )
  }

  <div class="flex justify-between">
    {
      page.url.prev ? (
        <a href={page.url.prev} class="btn btn-ghost my-10 mx-5">
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            <path d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" />
          </svg>
          Temas anteriores
        </a>
      ) : (
        <div />
      )
    }
    {
      page.url.next ? (
        <a href={page.url.next} class="btn btn-ghost my-10 mx-5">
          Siguientes temas
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
          </svg>
        </a>
      ) : (
        <div />
      )
    }
  </div>
</BaseLayout>
